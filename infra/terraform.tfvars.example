# GCP Project Configuration
# Copy this file to terraform.tfvars and fill in your values

project_id = "your-gcp-project-id"
region     = "us-central1"
image      = "gcr.io/your-project/txguard:latest"

# Secrets - use a strong generated password for the database
db_password        = "generate-a-strong-random-password-here"
redis_password     = ""
openrouter_api_key = "sk-or-v1-..." # from https://openrouter.ai

service_name       = "txguard"
container_port     = 8080
memory             = "1Gi"
cpu                = "1"
min_instances      = 0
max_instances      = 3